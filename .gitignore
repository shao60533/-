__pycache__/
*.pyc
*.pyo

# Local data (per-user, never commit) — root-only, do not catch stock_trading_system/data/
/data/
*.db
*.db-journal
*.db-wal
*.db-shm

reports_output/
eval_results/

# Auto-generated rollback snapshots
.rollback_backup_*/

# Env / secrets
.env
.env.local
*_token.json
schwab_*.json
.schwab_creds

# Python build artifacts
*.egg-info/
dist/
build/
.venv/
venv/

# NOTE: stock_trading_system/web/static/dist/ is INTENTIONALLY TRACKED
# (overridden by stock_trading_system/web/.gitignore's !static/dist/
# rule) because Railway deploys serve straight from the git checkout
# and don't run `npm run build`. Each `vite build` rotates the asset
# hashes — old hashes are deleted, new hashes added — so commits stay
# diff-clean instead of accumulating cruft. If we ever move to a CI
# build step on Railway, drop the !static/dist/ override and the dist
# folder can join the standard `dist/` ignore above.

# Pytest / test caches
.pytest_cache/
.coverage
htmlcov/

# Editor
.idea/
*.swp
.DS_Store
