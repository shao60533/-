# Copy to .env on the server and fill in real values.
# This file is safe to commit; .env is gitignored.

# ── Required ────────────────────────────────────────────────────────────
# Qwen LLM (DashScope mainland endpoint). Create at:
# https://bailian.console.aliyun.com/?tab=model#/api-key
DASHSCOPE_API_KEY=

# ── Recommended: model split (data collectors vs deep thinkers) ─────────
QWEN_MODEL=qwen3.6-flash
QWEN_DEEP_THINK_MODEL=qwen3.6-plus

# ── Optional: Gemini fallback (blocked by GFW from mainland, usually skip) ─
# GEMINI_API_KEY=

# ── Optional alerting ───────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# EMAIL_SMTP_HOST=
# EMAIL_USERNAME=
# EMAIL_PASSWORD=
# EMAIL_TO=
